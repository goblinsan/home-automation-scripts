# =============================================================================
# .env.example – Template for all required environment variables
#
# USAGE:
#   cp .env.example .env        # creates your local .env (gitignored)
#   nano .env                   # fill in real values
#
# RULES:
#   - Never commit the real .env file; it is permanently listed in .gitignore.
#   - This file (.env.example) contains ONLY placeholder values and IS
#     committed so that new contributors know which variables to set.
#   - Keep values in this file clearly fictional (e.g. "your_token_here").
# =============================================================================

# -----------------------------------------------------------------------------
# MQTT Broker
# -----------------------------------------------------------------------------
MQTT_HOST=mqtt.example.local
MQTT_PORT=1883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# -----------------------------------------------------------------------------
# Home Assistant
# -----------------------------------------------------------------------------
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# -----------------------------------------------------------------------------
# Notifications – Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# -----------------------------------------------------------------------------
# Notifications – Pushbullet (optional alternative to Telegram)
# -----------------------------------------------------------------------------
PUSHBULLET_API_KEY=your_pushbullet_api_key

# -----------------------------------------------------------------------------
# Database (optional – for scripts that persist state)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=home_automation
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# -----------------------------------------------------------------------------
# Generic API keys (add service-specific blocks below as needed)
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=your_openweather_api_key
