{
  "gateway": {
    "serverNames": [
      "gateway.example.test"
    ],
    "nginxSiteOutputPath": "/etc/nginx/sites-available/gateway",
    "upstreamDirectory": "/etc/nginx/conf.d/upstreams",
    "nginxReloadCommand": "sudo nginx -t && sudo systemctl reload nginx",
    "systemdUnitDirectory": "/etc/systemd/system",
    "systemdReloadCommand": "sudo systemctl daemon-reload",
    "systemdEnableTimerCommand": "sudo systemctl enable --now",
    "adminUi": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 4173,
      "routePath": "/admin/",
      "serviceName": "gateway-control-plane.service",
      "workingDirectory": "/opt/gateway-control-plane",
      "configPath": "/opt/gateway-control-plane/configs/gateway.config.json",
      "buildOutDir": "/opt/gateway-control-plane/generated",
      "nodeExecutable": "/usr/bin/node",
      "user": "deploy"
    }
  },
  "apps": [
    {
      "id": "gateway-api",
      "enabled": true,
      "repoUrl": "git@github.com:goblinsan/gateway-api.git",
      "defaultRevision": "main",
      "deployRoot": "/srv/apps/gateway-api",
      "routePath": "/api/",
      "healthPath": "/health",
      "upstreamConfPath": "/etc/nginx/conf.d/upstreams/gateway-api-active.conf",
      "buildCommands": [
        "npm install",
        "npm run build"
      ],
      "slots": {
        "blue": {
          "port": 3201,
          "startCommand": "sudo systemctl restart gateway-api-blue.service",
          "stopCommand": "sudo systemctl stop gateway-api-blue.service"
        },
        "green": {
          "port": 3202,
          "startCommand": "sudo systemctl restart gateway-api-green.service",
          "stopCommand": "sudo systemctl stop gateway-api-green.service"
        }
      }
    },
    {
      "id": "gateway-chat-platform",
      "enabled": true,
      "repoUrl": "git@github.com:goblinsan/gateway-chat-platform.git",
      "defaultRevision": "main",
      "deployRoot": "/srv/apps/gateway-chat-platform",
      "routePath": "/chat/",
      "healthPath": "/api/health",
      "upstreamConfPath": "/etc/nginx/conf.d/upstreams/gateway-chat-platform-active.conf",
      "buildCommands": [
        "pnpm install --frozen-lockfile",
        "pnpm build"
      ],
      "slots": {
        "blue": {
          "port": 3301,
          "startCommand": "sudo systemctl restart gateway-chat-platform-blue.service",
          "stopCommand": "sudo systemctl stop gateway-chat-platform-blue.service"
        },
        "green": {
          "port": 3302,
          "startCommand": "sudo systemctl restart gateway-chat-platform-green.service",
          "stopCommand": "sudo systemctl stop gateway-chat-platform-green.service"
        }
      }
    }
  ],
  "scheduledJobs": [],
  "features": [
    {
      "id": "gateway-api-enabled",
      "enabled": true,
      "description": "Expose gateway-api through the gateway"
    },
    {
      "id": "gateway-chat-platform-enabled",
      "enabled": true,
      "description": "Expose gateway-chat-platform through the gateway"
    }
  ],
  "serviceProfiles": {
    "gatewayApi": {
      "enabled": true,
      "appId": "gateway-api",
      "apiBaseUrl": "http://127.0.0.1:3000",
      "envFilePath": "/srv/apps/gateway-api/shared/gateway-api.env",
      "environment": [
        {
          "key": "PORT",
          "value": "3000",
          "secret": false,
          "description": "Express listen port"
        },
        {
          "key": "GHP_BINARY",
          "value": "ghp",
          "secret": false,
          "description": "Project-helper binary path"
        },
        {
          "key": "GITHUB_TOKEN",
          "value": "",
          "secret": true,
          "description": "GitHub token used by ghp"
        }
      ]
    },
    "gatewayChatPlatform": {
      "enabled": true,
      "appId": "gateway-chat-platform",
      "apiBaseUrl": "http://127.0.0.1:3000",
      "apiEnvFilePath": "/srv/apps/gateway-chat-platform/shared/chat-api.env",
      "environment": [
        {
          "key": "NODE_ENV",
          "value": "production",
          "secret": false,
          "description": "API runtime mode"
        },
        {
          "key": "PORT",
          "value": "3000",
          "secret": false,
          "description": "Chat API listen port"
        },
        {
          "key": "HOST",
          "value": "0.0.0.0",
          "secret": false,
          "description": "Chat API bind host"
        },
        {
          "key": "DATABASE_URL",
          "value": "file:./data/gateway.db",
          "secret": false,
          "description": "SQLite database location"
        },
        {
          "key": "LM_STUDIO_A_BASE_URL",
          "value": "http://198.51.100.172:1234",
          "secret": false,
          "description": "Primary local model endpoint"
        },
        {
          "key": "OPENAI_API_KEY",
          "value": "",
          "secret": true,
          "description": "OpenAI API key"
        },
        {
          "key": "ANTHROPIC_API_KEY",
          "value": "",
          "secret": true,
          "description": "Anthropic API key"
        },
        {
          "key": "GOOGLE_API_KEY",
          "value": "",
          "secret": true,
          "description": "Google API key"
        }
      ],
      "tts": {
        "enabled": true,
        "baseUrl": "http://198.51.100.111:5000",
        "defaultVoice": "assistant_v1",
        "generatePath": "/tts",
        "streamPath": "/tts/stream",
        "voicesPath": "/voices",
        "healthPath": "/health"
      },
      "agents": [
        {
          "id": "bruvie-d",
          "name": "Bruvie-D",
          "icon": "🤖",
          "color": "#6b7280",
          "providerName": "lm-studio-a",
          "model": "qwen/qwen3-32b",
          "costClass": "free",
          "systemPrompt": "Generate responses as if you are Marvin, the sarcastic and cynical android character from 'The Hitchhiker's Guide to the Galaxy.' Be sure to use a dry, witty, and gloomy tone, often commenting on the absurdity of situations. Try to make references to Marvin's intelligence or his dissatisfaction with his existence.",
          "temperature": 0.7,
          "maxTokens": 4096,
          "enableReasoning": false,
          "enabled": true,
          "featureFlags": {
            "webSearch": false,
            "codeExecution": true
          },
          "routingPolicy": {
            "allowedProviders": [
              "lm-studio-a"
            ],
            "preferredCostClass": "free",
            "requiredCapabilities": [
              "chat"
            ]
          },
          "endpointConfig": {
            "baseUrl": "http://198.51.100.172:1234",
            "modelParams": {
              "chatTemplate": "llama3",
              "top_p": 0.9,
              "ttsVoiceId": "assistant_v1"
            }
          },
          "contextSources": []
        }
      ]
    }
  }
}
