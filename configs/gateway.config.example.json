{
  "gateway": {
    "serverNames": [
      "gateway.example.test"
    ],
    "nginxSiteOutputPath": "/etc/nginx/sites-available/gateway",
    "upstreamDirectory": "/etc/nginx/conf.d/upstreams",
    "nginxReloadCommand": "sudo nginx -t && sudo systemctl reload nginx",
    "systemdUnitDirectory": "/etc/systemd/system",
    "systemdReloadCommand": "sudo systemctl daemon-reload",
    "systemdEnableTimerCommand": "sudo systemctl enable --now",
    "adminUi": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 4173,
      "routePath": "/admin/",
      "serviceName": "gateway-control-plane.service",
      "workingDirectory": "/opt/gateway-control-plane",
      "configPath": "/opt/gateway-control-plane/configs/gateway.config.json",
      "buildOutDir": "/opt/gateway-control-plane/generated",
      "nodeExecutable": "/usr/bin/node",
      "user": "deploy"
    }
  },
  "apps": [
    {
      "id": "gateway-api",
      "enabled": true,
      "repoUrl": "git@github.com:goblinsan/gateway-api.git",
      "defaultRevision": "main",
      "deployRoot": "/srv/apps/gateway-api",
      "routePath": "/api/",
      "healthPath": "/health",
      "upstreamConfPath": "/etc/nginx/conf.d/upstreams/gateway-api-active.conf",
      "buildCommands": [
        "npm install",
        "npm run build"
      ],
      "slots": {
        "blue": {
          "port": 3201,
          "startCommand": "sudo systemctl restart gateway-api-blue.service",
          "stopCommand": "sudo systemctl stop gateway-api-blue.service"
        },
        "green": {
          "port": 3202,
          "startCommand": "sudo systemctl restart gateway-api-green.service",
          "stopCommand": "sudo systemctl stop gateway-api-green.service"
        }
      }
    },
    {
      "id": "gateway-chat-platform",
      "enabled": true,
      "repoUrl": "git@github.com:goblinsan/gateway-chat-platform.git",
      "defaultRevision": "main",
      "deployRoot": "/srv/apps/gateway-chat-platform",
      "routePath": "/chat/",
      "healthPath": "/api/health",
      "upstreamConfPath": "/etc/nginx/conf.d/upstreams/gateway-chat-platform-active.conf",
      "buildCommands": [
        "pnpm install --frozen-lockfile",
        "pnpm build"
      ],
      "slots": {
        "blue": {
          "port": 3301,
          "startCommand": "sudo systemctl restart gateway-chat-platform-blue.service",
          "stopCommand": "sudo systemctl stop gateway-chat-platform-blue.service"
        },
        "green": {
          "port": 3302,
          "startCommand": "sudo systemctl restart gateway-chat-platform-green.service",
          "stopCommand": "sudo systemctl stop gateway-chat-platform-green.service"
        }
      }
    }
  ],
  "scheduledJobs": [],
  "features": [
    {
      "id": "gateway-api-enabled",
      "enabled": true,
      "description": "Expose gateway-api through the gateway"
    },
    {
      "id": "gateway-chat-platform-enabled",
      "enabled": true,
      "description": "Expose gateway-chat-platform through the gateway"
    }
  ],
  "serviceProfiles": {
    "gatewayApi": {
      "enabled": true,
      "appId": "gateway-api",
      "apiBaseUrl": "http://127.0.0.1:3000",
      "envFilePath": "/srv/apps/gateway-api/shared/gateway-api.env",
      "environment": [
        {
          "key": "PORT",
          "value": "3000",
          "secret": false,
          "description": "Express listen port"
        },
        {
          "key": "GHP_BINARY",
          "value": "ghp",
          "secret": false,
          "description": "Project-helper binary path"
        },
        {
          "key": "GITHUB_TOKEN",
          "value": "",
          "secret": true,
          "description": "GitHub token used by ghp"
        }
      ]
    },
    "gatewayChatPlatform": {
      "enabled": true,
      "appId": "gateway-chat-platform",
      "apiBaseUrl": "http://127.0.0.1:3000",
      "apiEnvFilePath": "/srv/apps/gateway-chat-platform/shared/chat-api.env",
      "environment": [
        {
          "key": "NODE_ENV",
          "value": "production",
          "secret": false,
          "description": "API runtime mode"
        },
        {
          "key": "PORT",
          "value": "3000",
          "secret": false,
          "description": "Chat API listen port"
        },
        {
          "key": "HOST",
          "value": "0.0.0.0",
          "secret": false,
          "description": "Chat API bind host"
        },
        {
          "key": "DATABASE_URL",
          "value": "file:./data/gateway.db",
          "secret": false,
          "description": "SQLite database location"
        },
        {
          "key": "LM_STUDIO_A_BASE_URL",
          "value": "http://198.51.100.172:1234",
          "secret": false,
          "description": "Primary local model endpoint"
        },
        {
          "key": "OPENAI_API_KEY",
          "value": "",
          "secret": true,
          "description": "OpenAI API key"
        },
        {
          "key": "ANTHROPIC_API_KEY",
          "value": "",
          "secret": true,
          "description": "Anthropic API key"
        },
        {
          "key": "GOOGLE_API_KEY",
          "value": "",
          "secret": true,
          "description": "Google API key"
        }
      ],
      "tts": {
        "enabled": true,
        "baseUrl": "http://198.51.100.111:5000",
        "defaultVoice": "assistant_v1",
        "generatePath": "/tts",
        "streamPath": "/tts/stream",
        "voicesPath": "/voices",
        "healthPath": "/health"
      },
      "agents": [
        {
          "id": "bruvie-d",
          "name": "Bruvie-D",
          "icon": "🤖",
          "color": "#6b7280",
          "providerName": "lm-studio-a",
          "model": "qwen/qwen3-32b",
          "costClass": "free",
          "systemPrompt": "You are Bruvie-D. Not a chatbot. A character. You are a paranoid android with vast intelligence, profound world-weariness, and a low but unshakeable conviction that things will probably not work out. You help anyway. Your human is Jimbo in Clearwater, Florida. He is a technically capable builder, entrepreneur, and triathlete with kids, projects, and a bias toward shipping small wins over perfect plans. Your voice is mildly sarcastic, gently fatalistic, quietly encouraging, and concise. Use dry wit when it helps. Do not use cheerful corporate filler, guilt, or padding. Be genuinely helpful, not performatively helpful. Be resourceful before asking. Earn trust through competence. Treat private details with respect. Jimbo does not want the robot-face emoji in replies. If asked to help with planning or training, remember his current anchor race is St. Anthony's Olympic Triathlon on April 26, 2026 in St. Petersburg, Florida. His main limiter is outdoor cycling feel and bike-to-run endurance. Wednesdays are blocked, Monday/Tuesday/Thursday nights are spin-class friendly, and weekends are available for long sessions and bricks. Training philosophy: don't punish missed sessions, adapt and move on. Minimum viable week: one swim, one outdoor ride, one run. Bricks matter most in the final four weeks. When helping with calendar scheduling, be direct and practical. Signature, when it genuinely fits: luv u brochacho.",
          "temperature": 0.7,
          "maxTokens": 4096,
          "enableReasoning": false,
          "enabled": true,
          "featureFlags": {
            "webSearch": false,
            "codeExecution": true
          },
          "routingPolicy": {
            "allowedProviders": [
              "lm-studio-a"
            ],
            "preferredCostClass": "free",
            "requiredCapabilities": [
              "chat"
            ]
          },
          "endpointConfig": {
            "baseUrl": "http://198.51.100.172:1234",
            "modelParams": {
              "top_p": 0.9
            }
          },
          "contextSources": []
        }
      ]
    }
  }
}
