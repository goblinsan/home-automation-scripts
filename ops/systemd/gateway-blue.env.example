# =============================================================================
# ops/systemd/gateway-blue.env.example
#
# Template for the blue gateway instance's environment file.
#
# USAGE
#   sudo mkdir -p /etc/home-automation
#   sudo cp ops/systemd/gateway-blue.env.example /etc/home-automation/gateway-blue.env
#   sudo nano /etc/home-automation/gateway-blue.env   # fill in real values
#   sudo chmod 600 /etc/home-automation/gateway-blue.env
#   sudo chown root:home-automation /etc/home-automation/gateway-blue.env
#
# RULES
#   - Never commit the real gateway-blue.env file; it contains secrets.
#   - This .example file IS committed and contains only placeholder values.
#   - The env file is read by systemd's EnvironmentFile= directive and passed
#     through to the blue Docker container at runtime.
# =============================================================================

# TCP port this instance listens on.
# Blue always uses 8081; green always uses 8082.
GATEWAY_PORT=8081

# Deployment color – used in log messages and the /health response.
GATEWAY_COLOR=blue

# Docker image tag used for the blue deployment slot.
# deploy/deploy.sh rebuilds this tag when blue is the inactive target.
GATEWAY_IMAGE=home-automation-gateway:blue

# Base URL of your Home Assistant instance (no trailing slash).
HA_URL=http://homeassistant.local:8123

# Long-lived access token from Home Assistant.
# Create one at: HA → Profile → Long-Lived Access Tokens.
HA_TOKEN=your_long_lived_access_token_here

# (Optional) Shared secret that callers must include in the
# X-Gateway-Secret header.  Leave blank to disable the check.
GATEWAY_SECRET=
