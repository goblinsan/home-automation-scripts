# =============================================================================
# ops/systemd/automation.env.example
#
# Optional environment overrides for host-side automation timers.
#
# Install to:
#   /etc/home-automation/automation.env
#
# This file is sourced by the managed systemd services in ops/systemd/timers/.
# Use it for secrets or per-host tuning values needed by scheduled tasks.
# =============================================================================

# Health-check warning thresholds
# HEALTH_DISK_WARN_PCT=80
# HEALTH_CPU_WARN_PCT=90
# HEALTH_MEM_WARN_PCT=85

# Strava sync credentials
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REFRESH_TOKEN=
# STRAVA_LOOKBACK_DAYS=1

