# =============================================================================
# ops/systemd/gateway-green.env.example
#
# Template for the green gateway instance's environment file.
#
# USAGE
#   sudo mkdir -p /etc/home-automation
#   sudo cp ops/systemd/gateway-green.env.example /etc/home-automation/gateway-green.env
#   sudo nano /etc/home-automation/gateway-green.env   # fill in real values
#   sudo chmod 600 /etc/home-automation/gateway-green.env
#   sudo chown root:home-automation /etc/home-automation/gateway-green.env
# =============================================================================

# TCP port this instance listens on.
# Green always uses 8082; blue always uses 8081.
GATEWAY_PORT=8082

# Deployment color – used in log messages and the /health response.
GATEWAY_COLOR=green

# Base URL of your Home Assistant instance (no trailing slash).
HA_URL=http://homeassistant.local:8123

# Long-lived access token from Home Assistant.
HA_TOKEN=your_long_lived_access_token_here

# (Optional) Shared secret.
GATEWAY_SECRET=
